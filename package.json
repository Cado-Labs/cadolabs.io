{
  "private": true,
  "type": "module",
  "name": "remix-app-template",
  "description": "",
  "license": "",
  "scripts": {
    "build": "npm run build:css && cross-env NODE_ENV=production react-router build",
    "dev": "cross-env NODE_ENV=development run-p dev:*",
    "dev:router": "react-router dev",
    "start": "wrangler pages dev ./build/client",
    "build:css": "sass ./styles:./app/styles --style=compressed --no-source-map",
    "dev:css": "npm run build:css && sass --watch ./styles:./app/styles"
  },
  "dependencies": {
    "@react-router/cloudflare": "^7",
    "airtable": "^0.11.1",
    "sass": "^1.86.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7",
    "replace": "^1.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@react-router/dev": "^7",
    "@react-router/fs-routes": "^7",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.0.0",
    "vite": "^5.4.14",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false
}
